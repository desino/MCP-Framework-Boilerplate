{
    "name": "desino/mcp-framework-boilerplate",
    "description": "Desino MCP boilerplate for Laravel: publish MCP server, tool manager UI, support tools, and audit logging into your application via Artisan.",
    "type": "library",
    "keywords": [
        "laravel",
        "mcp",
        "boilerplate",
        "desino",
        "model-context-protocol"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Desino",
            "email": "india@desino.be"
        }
    ],
    "require": {
        "php": "^8.3",
        "desino/boilerplate": "^1.0",
        "laravel/framework": "^13.0",
        "laravel/mcp": "^0.8"
    },
    "autoload": {
        "psr-4": {
            "Desino\\McpBoilerplate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Desino\\McpBoilerplate\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Desino\\McpBoilerplate\\McpBoilerplateServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
